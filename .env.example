# TalentBeacon™ Environment Variables
# Copy this file to .env and fill in your values

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# Database (SQLite for development)
DATABASE_URL=sqlite:///talentbeacon.db

# To switch to PostgreSQL later, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/talentbeacon

# Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# AWS S3 (optional - leave blank to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=talentbeacon-storage
